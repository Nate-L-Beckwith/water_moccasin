# Copy to .env and edit. Values here override compose defaults.

# --- identity ----------------------------------------------------------------
# Match the host user so mounted saves keep correct ownership.
UID=1000
GID=1000

# Group that owns /dev/input/event* on the host. Find yours with:
#   getent group input | cut -d: -f3
INPUT_GID=104

# --- image / container -------------------------------------------------------
IMAGE_NAME=water-moccasin/dolphin
IMAGE_TAG=latest
CONTAINER_NAME=water-moccasin
MEM_LIMIT=2g

# --- runtime -----------------------------------------------------------------
# play | netplay-host | shell
DOLPHIN_MODE=play

# Comma-separated input devices forwarded into the container. start.sh reads
# this and appends --device flags. Example:
#   CONTROLLER_DEVICES=/dev/input/event22,/dev/input/js0
CONTROLLER_DEVICES=

# --- netplay -----------------------------------------------------------------
NETPLAY_PORT=2626
# Absolute path inside the container (e.g. /game/melee.iso). Leave blank to
# auto-pick the first game in ./game.
NETPLAY_GAME=
